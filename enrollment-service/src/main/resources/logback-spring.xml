<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <springProperty name="APP_NAME" source="spring.application.name" defaultValue="unknown-service"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"app":"${APP_NAME}"}</customFields>
        </encoder>
    </appender>

    <appender name="LOKI" class="com.github.loki4j.logback.Loki4jAppender">
        <http>
            <url>http://localhost:3100/loki/api/v1/push</url>
        </http>
        <format>
            <label>
                <pattern>app=${APP_NAME},level=%level</pattern>
            </label>
            <message class="net.logstash.logback.layout.LogstashLayout">
                <customFields>{"app":"${APP_NAME}"}</customFields>
            </message>
            <sortByTime>true</sortByTime>
        </format>
        <batchMaxItems>512</batchMaxItems>
        <batchTimeoutMs>1000</batchTimeoutMs>
        <verbose>false</verbose>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="LOKI"/>
    </root>

    <logger name="org.springframework"             level="WARN"/>
    <logger name="org.springframework.web.servlet" level="INFO"/>
    <logger name="org.springframework.security"    level="WARN"/>
    <logger name="org.hibernate"                   level="WARN"/>
    <logger name="io.netty"                        level="WARN"/>
    <logger name="reactor.netty"                   level="WARN"/>
</configuration>