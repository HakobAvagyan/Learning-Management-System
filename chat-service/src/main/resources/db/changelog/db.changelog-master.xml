<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <include file="db/changelog/migrations/001_create_chat_messages.sql"/>

    <changeSet id="2-add-is-read-column" author="chat-service">
        <sql>ALTER TABLE chat_messages ADD COLUMN IF NOT EXISTS is_read BOOLEAN NOT NULL DEFAULT FALSE;</sql>
        <sql>CREATE INDEX IF NOT EXISTS idx_chat_unread ON chat_messages (recipient_id, is_read) WHERE is_read = FALSE;</sql>
    </changeSet>

    <changeSet id="3-clear-chat-history" author="chat-service">
        <sql>TRUNCATE TABLE chat_messages RESTART IDENTITY;</sql>
    </changeSet>

</databaseChangeLog>